{
  "expo": {
    "name": "react-native-expo-starter",
    "slug": "react-native-expo-starter",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "backgroundColor": "#F7F6EE",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#F7F6EE",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F6EE",
          "image": "./assets/images/splash.png",
          "resizeMode": "contain"
        }
      ],
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Kitap kapağı seçmek için galeriye erişim izni gerekiyor.",
          "cameraPermission": "Kitap kapağı çekmek için kameraya erişim izni gerekiyor."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod taramak için kameraya erişim izni gerekiyor."
        }
      ],
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6110532791964487~7550541087",
          "iosAppId": "ca-app-pub-6110532791964487~7550541087"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "backgroundColor": "#F7F6EE",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.kitaplik.app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da2ee961-92a2-44c8-98eb-f2eda0d37d12"
      }
    }
  }
}